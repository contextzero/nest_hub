# -----------------------------------------------------------------------------
# NEST Terminal — copy to .env and fill ALL required values
# Generate secrets: openssl rand -hex 32
# -----------------------------------------------------------------------------

# REQUIRED — shared secret between CLI and server
CLI_API_TOKEN=change-me

# REQUIRED — Postgres password (DB is internal-only, not exposed to host)
POSTGRES_PASSWORD=change-me-use-strong-password

# Encryption key for sensitive DB columns. Generate: openssl rand -hex 32
# Must remain the same across redeploys for the same DB volume.
# ENCRYPTION_KEY=

# Postgres (internal, no host access)
POSTGRES_USER=postgres
POSTGRES_DB=nest

# Web port on host (default 80)
WEB_PORT=80

# Public URL for PWA/Telegram (e.g. https://nest.yourdomain.com)
# NEST_PUBLIC_URL=

# Optional: Telegram bot
# TELEGRAM_BOT_TOKEN=

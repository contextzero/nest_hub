# Token compartido entre CLI y web. Debe coincidir con el que usa el CLI.
# Genera uno seguro: openssl rand -hex 32
CLI_API_TOKEN=change-me

# Puerto del hub (por defecto 3006)
NEST_LISTEN_PORT=3006

# URL pública HTTPS del hub (necesaria para Telegram Mini App y PWA desde fuera de localhost)
# Ejemplo: https://nest.tudominio.com
# NEST_PUBLIC_URL=

# Token del bot de Telegram (opcional; si no se define, el hub funciona sin Telegram)
# TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# NEST Terminal — copy to .env and set at least CLI_API_TOKEN
# -----------------------------------------------------------------------------

# Shared secret: CLI and web must use this. Generate: openssl rand -hex 32
CLI_API_TOKEN=change-me

# Postgres (internal)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-use-strong-password
POSTGRES_DB=nest
PGPORT=5433

# Web port on host (default 80)
WEB_PORT=80

# Public URL for PWA/Telegram (e.g. https://nest.yourdomain.com)
# NEST_PUBLIC_URL=

# Optional: Telegram bot
# TELEGRAM_BOT_TOKEN=
